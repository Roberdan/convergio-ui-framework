{
  "mcpServers": {
    "convergio": {
      "command": "${CONVERGIO_DAEMON_BIN}",
      "args": ["--transport", "stdio"],
      "env": {
        "CONVERGIO_MCP_RING": "1",
        "CONVERGIO_MCP_PROFILE": "compact"
      }
    },
    "maranello-catalog": {
      "command": "pnpm",
      "args": ["mcp"]
    }
  }
}
